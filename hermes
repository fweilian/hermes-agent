#!/usr/bin/env python3
"""
Hermes Agent entry point.

This wrapper delegates to serve.py for the API server.
"""

if __name__ == "__main__":
    import subprocess
    import sys
    from pathlib import Path

    serve_py = Path(__file__).parent / "serve.py"
    sys.exit(subprocess.run(["python", str(serve_py), *sys.argv[1:]]).returncode)
